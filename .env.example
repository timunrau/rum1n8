# Public app origin for canonical URLs, sitemap.xml, and social image URLs
VITE_SITE_URL=https://yourdomain.com

# Google Drive sync provider (optional)
# Create OAuth 2.0 credentials at https://console.cloud.google.com/
# Application type: Web application
# Authorized redirect URIs: http://localhost:5173/gdrive-callback.html, https://yourdomain.com/gdrive-callback.html
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your-client-secret

# Optional self-hosted Umami analytics (leave unset to build with no analytics)
# When both are set, the app loads the Umami script and the privacy page discloses it.
VITE_UMAMI_SCRIPT_URL=https://analytics.yourdomain.com/script.js
VITE_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000

# Secrets for the optional docker-compose.analytics.yml overlay
UMAMI_DB_PASSWORD=replace-with-a-long-random-password
UMAMI_APP_SECRET=replace-with-a-long-random-string
